# Minimal local config
JUEJIN_COOKIE=

# Optional: enable Telegram notification
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional: send to a Telegram topic
# TELEGRAM_MESSAGE_THREAD_ID=

# Optional: override the default browser User-Agent
# JUEJIN_USER_AGENT=

# Optional: true/false, default is false
# Headed mode is recommended because Juejin is more likely to block headless browsers
# JUEJIN_HEADLESS=false
